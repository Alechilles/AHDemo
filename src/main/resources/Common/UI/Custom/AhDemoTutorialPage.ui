$C = "Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer #AhDemoTutorialPageRoot {
    Anchor: (Width: 640, Height: 430);

    #Title {
      $C.@Title #AhDemoTutorialPageTitle {
        @Alignment = Start;
        @Text = "Animal Husbandry Guide";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 12, Right: 12, Top: 8, Bottom: 10);

      Label #AhDemoTutorialPageProgress {
        Anchor: (Height: 22);
        Text: "Step 1 of 7";
        Style: (FontSize: 12, TextColor: #8fb8ff, HorizontalAlignment: Start, VerticalAlignment: Center, Wrap: false);
      }

      Label #AhDemoTutorialPageInstruction {
        Anchor: (Height: 76);
        Text: "";
        Style: (FontSize: 14, TextColor: #dce9f8, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
      }

      Group {
        FlexWeight: 1;
        LayoutMode: Top;
        Background: #13243a;
        Padding: (Left: 10, Right: 10, Top: 10, Bottom: 10);

        Label #AhDemoTutorialPageTask0 {
          Anchor: (Height: 44);
          Text: "";
          Style: (FontSize: 14, TextColor: #f1f6ff, HorizontalAlignment: Start, VerticalAlignment: Center, Wrap: true);
        }

        Label #AhDemoTutorialPageTask1 {
          Anchor: (Height: 44);
          Text: "";
          Style: (FontSize: 14, TextColor: #f1f6ff, HorizontalAlignment: Start, VerticalAlignment: Center, Wrap: true);
        }

        Label #AhDemoTutorialPageTask2 {
          Anchor: (Height: 44);
          Text: "";
          Style: (FontSize: 14, TextColor: #f1f6ff, HorizontalAlignment: Start, VerticalAlignment: Center, Wrap: true);
        }
      }

      Group {
        Anchor: (Height: 42);
        LayoutMode: Right;

        $C.@SmallSecondaryTextButton #AhDemoTutorialPagePreviousButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Previous";
          @Anchor = (MinWidth: 112);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #AhDemoTutorialPageRestartButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Restart Module";
          @Anchor = (MinWidth: 150);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #AhDemoTutorialPageHudButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Hide HUD";
          @Anchor = (MinWidth: 120);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #AhDemoTutorialPageNextButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Next";
          @Anchor = (MinWidth: 112);
        }

        Group {
          Anchor: (Width: 8);
        }

        $C.@SmallSecondaryTextButton #AhDemoTutorialPageCloseButton {
          @Sounds = $C.@ButtonSounds;
          @Text = "Close";
          @Anchor = (MinWidth: 100);
        }
      }
    }
  }
}
